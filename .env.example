# ── LLM 配置 ─────────────────────────────────────────────────────────────────
# LLM 后端选择：openai / anthropic / litellm（默认 openai）
# litellm 支持 100+ 模型：Gemini、Ollama、Azure、Bedrock 等
LLM_BACKEND=openai

# 自定义模型（可选，覆盖后端默认模型）
# LLM_MODEL=gpt-4o                    # 主模型（视觉理解、决策）
# LLM_MINI_MODEL=gpt-4o-mini          # 轻量模型（任务分解、失败分析）

# OpenAI API Key（LLM_BACKEND=openai 或 litellm 使用 OpenAI 模型时必填）
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API Key（LLM_BACKEND=anthropic 或 litellm 使用 Claude 模型时必填）
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Gemini API Key（litellm 使用 Gemini 模型时必填）
# GEMINI_API_KEY=your-gemini-api-key

# litellm 模型示例：
# LLM_BACKEND=litellm
# LLM_MODEL=gemini/gemini-2.0-flash    # Google Gemini
# LLM_MODEL=ollama/llama3              # 本地 Ollama
# LLM_MODEL=azure/gpt-4o              # Azure OpenAI

# ── 服务配置 ─────────────────────────────────────────────────────────────────
# API 认证密钥（可选，设置后所有请求需带 X-API-Key 头）
# API_KEY=your-secret-api-key

# CORS 允许的源（逗号分隔，默认 http://localhost:8000）
# CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# 最大并发任务数（默认 20）
# MAX_QUEUE_SIZE=20

# 保留的历史任务数（默认 50）
# MAX_TASKS_KEEP=50

# ── 浏览器配置 ───────────────────────────────────────────────────────────────
# 无头模式（Docker 部署时建议设为 true，本地开发默认 false）
# HEADLESS=false

# HTTP 代理（设为 1 启用，默认代理地址 http://127.0.0.1:7897）
# USE_PROXY=1

# ── 网站凭证 ─────────────────────────────────────────────────────────────────
# 格式：{SITE_KEY}_EMAIL / {SITE_KEY}_PASSWORD
# SITE_KEY = 域名中的点和连字符替换为下划线，如：
#   github.com  → GITHUB_COM
#   felo.ai     → FELO_AI
#   my-app.io   → MY_APP_IO

# 示例：github.com 的登录凭证
# GITHUB_COM_EMAIL=your@email.com
# GITHUB_COM_PASSWORD=your_password

# ── 2FA / TOTP ───────────────────────────────────────────────────────────────
# 格式：{SITE_KEY}_TOTP_SECRET（Base32 编码的密钥）
# 用于 Google Authenticator 等 TOTP 两步验证
# GITHUB_COM_TOTP_SECRET=JBSWY3DPEHPK3PXP

# ── Token 注入 ───────────────────────────────────────────────────────────────
# 格式：{SITE_KEY}_TOKEN
# 某些站点可直接注入 API Token 跳过登录
# FELO_AI_TOKEN=your_api_token
